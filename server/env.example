# Server Configuration
PORT=4242
FRONTEND_URL=http://localhost:5173

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Email Configuration
SMTP_HOST=your_smtp_host
SMTP_PORT=465
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SUPPORT_EMAIL=support@essayembassy.com

# Firebase Configuration (for server-side)
# Set GOOGLE_APPLICATION_CREDENTIALS environment variable to your service account key file path
# Or use Firebase Admin SDK with service account key
